generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum OiicsStructure {
  NATURE
  PART_OF_BODY
  EVENT
  SOURCE
  WORKER_ACTIVITY
  LOCATION
}

enum IncidentCodeStatus {
  AUTO
  NEEDS_REVIEW
  HUMAN_CONFIRMED
}

enum BulkUploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  incidents   Incident[]
  bulkUploads BulkUpload[]
}

model BulkUpload {
  id            String           @id @default(cuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  filename      String
  status        BulkUploadStatus @default(PENDING)
  totalRows     Int
  processedRows Int              @default(0)
  failedRows    Int              @default(0)
  createdAt     DateTime         @default(now())
  completedAt   DateTime?
  incidents     Incident[]

  @@index([tenantId, createdAt])
}

model Incident {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  bulkUploadId   String?
  bulkUpload     BulkUpload? @relation(fields: [bulkUploadId], references: [id])
  narrative      String
  occurredAt     DateTime?
  reportedBy     String?
  externalRef    String?
  embeddingModel String?
  embeddedText   String?

  embedding      Unsupported("vector(1024)")?

  createdAt      DateTime  @default(now())
  codes          IncidentCode[]

  @@index([tenantId, createdAt])
  @@index([bulkUploadId])
}

model IncidentCode {
  id                     String             @id @default(cuid())
  incidentId             String
  incident               Incident           @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  structure              OiicsStructure
  code                   String
  codeVersion            String
  confidence             Float // model self-reported confidence
  retrievalSimilarity    Float? // top candidate cosine similarity — objective second gate signal
  rationale              String
  alternativesConsidered Json?
  modelId                String
  promptVersion          String
  status                 IncidentCodeStatus @default(NEEDS_REVIEW)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@unique([incidentId, structure])
}

model OiicsCode {
  id                 String         @id @default(cuid())
  structure          OiicsStructure
  code               String         
  version            String         // e.g. "3.02"
  title              String
  definition         String?
  includes           String?
  excludes           String?
  codingInteractions String?
  notes              String?
  hierarchyRaw       String         // the raw "Hierarchy" cell: "1s", "2", "3"
  hierarchyLevel     Int            // numeric part: 1, 2, 3, 4
  isSummary          Boolean        @default(false) // rows whose hierarchy ends in "s"
  parentCode         String?        // parent code within the same structure + version
  isActive           Boolean        @default(true)
  embeddingModel     String?        
  embeddedText       String?        

  embedding          Unsupported("vector(1024)")?

  @@unique([structure, code, version])
  @@index([structure, version, isActive])
}
